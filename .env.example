# ===== FILE MAU - HUONG DAN DIEN .env =====
# Copy file nay thanh ".env" roi dien gia tri that vao.

# GEMINI API (tao doan van on tap)
VITE_GEMINI_API_KEY=dien_api_key_gemini_cua_ban_vao_day
